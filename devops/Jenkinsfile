pipeline {

    agent { dockerfile true }

    stages {
       stage('Test') {
           agent {
               docker {
                   image 'maven:3.8.6-openjdk-11-slim'
               }
           }
            steps {
                sh 'pytest -q'
            }
        }
        stage('Lint') {
            agent {
                docker {
                    image 'maven:3.8.6-openjdk-11-slim'
                }
            }
            steps {
                sh 'pip install -r requirements.txt flake8 mypy'
                sh 'make lint'
            }
        }
        // STAGES DE EJERCICIOS
        // practica 2.1
        stage('Info') {
            agent {
                docker {
                    image 'maven:3.8.6-openjdk-11-slim'
                }
            }
            steps {
                sh 'echo "Job: ${env.JOB_NAME}'
                sh 'echo "Build: ${env.BUILD_NUMBER}"'
            }
        }
        // final del bloque de stages
    }
}
