pipeline {

    agent { dockerfile true }
    stages {
       stage('Test') {
            
            steps {
                sh 'pytest -q'
            }
        }
        stage('Lint') {
           
            steps {
                sh 'pip install -r requirements.txt flake8 mypy'
                sh 'make lint'
            }
        }
        // STAGES DE EJERCICIOS
        // practica 2.1
        stage('Info') {
            steps {
                sh 'echo "Job: ${env.JOB_NAME}, Build: ${env.BUILD_NUMBER}"'
            }
        }
        // final del bloque de stages
    }
}
