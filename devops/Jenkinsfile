// FUNCIONES
def runInDocker(String image, Closure body) {
    docker.image(image).inside {
        body()
    }
}

// PIPELINE
pipeline {

    agent any

    stages {

        stage('Info') {
            steps {
                echo "Info"
                echo "Job: ${env.JOB_NAME}"
                echo "Build: ${env.BUILD_NUMBER}"
                echo "Branch: ${env.BRANCH_NAME}"
            }
        }

        stage('CI - Build tools image') {
            steps {
                script {
                    docker.build(env.CI_IMAGE_NAME, "-f devops/ci.Dockerfile .")
                }
            }
        }

        stage('CI - Lint') {
            steps {
                script {
                    devopsLib.runInDocker(env.CI_IMAGE_NAME) {
                        sh 'python --version'
                        sh 'pip install -r requirements.txt flake8 mypy'
                        sh 'make lint'
                    }
                }
            }
        }

        stage('CI - Test') {
            steps {
                script {
                    devopsLib.runInDocker(env.CI_IMAGE_NAME) {
                        echo "Unit test"
                        sh 'python --version'
                        sh 'pip install -r requirements.txt'
                        sh 'pytest -q'
                    }
                }
            }
        }
        // final del bloque de stages
    }
}
